+export function HashtagView({ posts, activeTag, onSelectTag }) {
+  const tags = [...new Set(posts.flatMap((post) => post.hashtags))].sort();
+  return (
+    <div className="card tag-list">
+      <button className={!activeTag ? 'active' : ''} onClick={() => onSelectTag('')}>All</button>
+      {tags.map((tag) => <button className={activeTag === tag ? 'active' : ''} key={tag} onClick={() => onSelectTag(tag)}>{tag}</button>)}
+    </div>
+  );
+}
