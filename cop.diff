@@ -0,0 +1,46 @@
+import { useState } from 'react';
+import { EditPostForm } from './EditPostForm';
+import { CommentSection } from './CommentSection';
+
+export function PostCard({ post, onEdit, onDelete, onAddComment, onEditComment, onDeleteComment, onTagClick }) {
+  const [editing, setEditing] = useState(false);
+  return (
+    <article className="card">
+      {editing ? (
+        <EditPostForm
+          initialContent={post.content}
+          onSave={(content) => {
+            onEdit(post.id, { content });
+            setEditing(false);
+          }}
+          onCancel={() => setEditing(false)}
+        />
+      ) : (
+        <>
+          <p>{post.content}</p>
+          <div className="tags">
+            {post.hashtags.map((tag) => (
+              <button key={tag} onClick={() => onTagClick(tag)}>
+                {tag}
+              </button>
+            ))}
+          </div>
+          {post.imageData ? <img src={post.imageData} alt="Post" /> : null}
+          <small>
+            {new Date(post.updatedAt).toLocaleString()} · {post.syncStatus}
+          </small>
+          <div>
+            <button onClick={() => setEditing(true)}>Edit</button>
+            <button onClick={() => onDelete(post.id)}>Delete</button>
+          </div>
+        </>
+      )}
+      <CommentSection
+        comments={post.comments}
+        onAdd={(content) => onAddComment(post.id, content)}
+        onEdit={(commentId, content) => onEditComment(post.id, commentId, content)}
+        onDelete={(commentId) => onDeleteComment(post.id, commentId)}
+      />
+    </article>
+  );
+}
