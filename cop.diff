+import { useState } from 'react';
+import { CommentItem } from './CommentItem';
+
+export function CommentSection({ comments, onAdd, onEdit, onDelete }) {
+  const [value, setValue] = useState('');
+  return (
+    <section>
+      <h4>Comments</h4>
+      <ul className="comments">
+        {comments.map((comment) => (
+          <CommentItem key={comment.id} comment={comment} onEdit={(content) => onEdit(comment.id, content)} onDelete={() => onDelete(comment.id)} />
+        ))}
+      </ul>
+      <form onSubmit={(event) => { event.preventDefault(); if (!value.trim()) return; onAdd(value.trim()); setValue(''); }} className="inline-form">
+        <input value={value} onChange={(event) => setValue(event.target.value)} placeholder="Add comment" />
+        <button type="submit">Post</button>
+      </form>
+    </section>
+  );
+}
