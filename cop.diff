diff --git a/src/lib/api.js b/src/lib/api.js
new file mode 100644
index 0000000000000000000000000000000000000000..ea88916c3247a2f8241665c78e665cd5094153ef
--- /dev/null
+++ b/src/lib/api.js
@@ -0,0 +1,67 @@
+const baseUrl = import.meta.env.VITE_MONGODB_DATA_API_URL;
+const apiKey = import.meta.env.VITE_MONGODB_DATA_API_KEY;
+const dataSource = import.meta.env.VITE_MONGODB_DATA_SOURCE;
+const database = import.meta.env.VITE_MONGODB_DATABASE;
+const collection = import.meta.env.VITE_MONGODB_COLLECTION || 'posts';
+
+const headers = {
+  'Content-Type': 'application/json',
+  'Access-Control-Request-Headers': '*',
+  'api-key': apiKey
+};
+
+const ensureConfig = () => {
+  if (!baseUrl || !apiKey || !dataSource || !database || !collection) {
+    throw new Error('MongoDB Data API env vars are not fully configured.');
+  }
+};
+
+const run = async (action, body) => {
+  ensureConfig();
+  const response = await fetch(`${baseUrl}/action/${action}`, {
+    method: 'POST',
+    headers,
+    body: JSON.stringify({ dataSource, database, collection, ...body })
+  });
+  if (!response.ok) throw new Error(`Data API request failed: ${action}`);
+  return response.json();
+};
+
+export const api = {
+  async getPosts() {
+    const result = await run('find', {
+      filter: {},
+      sort: { updatedAt: -1 },
+      projection: { _id: 0 }
+    });
+    return result.documents || [];
+  },
+  async createPost(post) {
+    await run('insertOne', { document: post });
+    return post;
+  },
+  async updatePost(id, payload) {
+    await run('updateOne', {
+      filter: { id },
+      update: {
+        $set: {
+          content: payload.content,
+          imageData: payload.imageData || '',
+          hashtags: payload.hashtags,
+          updatedAt: payload.updatedAt,
+          syncStatus: payload.syncStatus
+        }
+      }
+    });
+    return payload;
+  },
+  async deletePost(id) {
+    await run('deleteOne', { filter: { id } });
+  },
+  async replaceComments(postId, comments, updatedAt, syncStatus) {
+    await run('updateOne', {
+      filter: { id: postId },
+      update: { $set: { comments, updatedAt, syncStatus } }
+    });
+  }
+};
