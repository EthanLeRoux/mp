+import { openDB } from 'idb';
+
+const dbPromise = openDB('offline-social-db', 1, {
+  upgrade(db) {
+    db.createObjectStore('posts', { keyPath: 'id' });
+    db.createObjectStore('queue', { keyPath: 'id' });
+  }
+});
+
+export const localDb = {
+  async getPosts() {
+    return (await dbPromise).getAll('posts');
+  },
+  async putPost(post) {
+    return (await dbPromise).put('posts', post);
+  },
+  async putPosts(posts) {
+    const db = await dbPromise;
+    const tx = db.transaction('posts', 'readwrite');
+    posts.forEach((post) => tx.store.put(post));
+    await tx.done;
+  },
+  async deletePost(id) {
+    return (await dbPromise).delete('posts', id);
+  },
+  async addQueue(action) {
+    return (await dbPromise).put('queue', action);
+  },
+  async getQueue() {
+    return (await dbPromise).getAll('queue');
+  },
+  async deleteQueue(id) {
+    return (await dbPromise).delete('queue', id);
+  }
+};
