diff --git a/src/App.jsx b/src/App.jsx
new file mode 100644
index 0000000000000000000000000000000000000000..fe4990c1d29b5da1e06ce50bb7b2f0a43e0c7e06
--- /dev/null
+++ b/src/App.jsx
@@ -0,0 +1,170 @@
+import { useEffect, useMemo, useState } from 'react';
+import { api } from './lib/api';
+import { localDb } from './lib/db';
+import { CreatePostForm } from './components/CreatePostForm';
+import { PostFeed } from './components/PostFeed';
+import { SearchBar } from './components/SearchBar';
+import { HashtagView } from './components/HashtagView';
+import { SyncStatusIndicator } from './components/SyncStatusIndicator';
+import './styles.css';
+
+const now = () => new Date().toISOString();
+const extractHashtags = (text) => [...new Set((text.match(/#[\w-]+/g) || []).map((tag) => tag.toLowerCase()))];
+
+const toBase64 = (file) =>
+  new Promise((resolve, reject) => {
+    const reader = new FileReader();
+    reader.onload = () => resolve(reader.result);
+    reader.onerror = reject;
+    reader.readAsDataURL(file);
+  });
+
+export default function App() {
+  const [posts, setPosts] = useState([]);
+  const [searchTerm, setSearchTerm] = useState('');
+  const [activeTag, setActiveTag] = useState('');
+  const [online, setOnline] = useState(navigator.onLine);
+
+  const refreshLocal = async () => {
+    const localPosts = await localDb.getPosts();
+    setPosts(localPosts.sort((a, b) => b.updatedAt.localeCompare(a.updatedAt)));
+  };
+
+  const pullServer = async () => {
+    const remote = await api.getPosts();
+    await localDb.putPosts(remote.map((p) => ({ ...p, syncStatus: 'synced' })));
+    await refreshLocal();
+  };
+
+  const enqueue = async (type, payload) => {
+    await localDb.addQueue({ id: crypto.randomUUID(), type, payload, createdAt: now() });
+  };
+
+  const syncQueued = async () => {
+    const queue = (await localDb.getQueue()).sort((a, b) => a.createdAt.localeCompare(b.createdAt));
+    for (const action of queue) {
+      try {
+        if (action.type === 'createPost') await api.createPost(action.payload);
+        if (action.type === 'updatePost') await api.updatePost(action.payload.id, action.payload);
+        if (action.type === 'deletePost') await api.deletePost(action.payload.id);
+        if (action.type === 'replaceComments') {
+          await api.replaceComments(
+            action.payload.postId,
+            action.payload.comments,
+            action.payload.updatedAt,
+            action.payload.syncStatus
+          );
+        }
+        await localDb.deleteQueue(action.id);
+      } catch {
+        break;
+      }
+    }
+    await pullServer();
+  };
+
+  useEffect(() => {
+    refreshLocal();
+    if (navigator.onLine) pullServer();
+    const handleOnline = () => {
+      setOnline(true);
+      syncQueued();
+    };
+    const handleOffline = () => setOnline(false);
+    addEventListener('online', handleOnline);
+    addEventListener('offline', handleOffline);
+    return () => {
+      removeEventListener('online', handleOnline);
+      removeEventListener('offline', handleOffline);
+    };
+  }, []);
+
+  const visiblePosts = useMemo(() => {
+    let filtered = activeTag ? posts.filter((post) => post.hashtags.includes(activeTag)) : posts;
+    if (!searchTerm) return filtered;
+    const q = searchTerm.toLowerCase();
+    return filtered.filter(
+      (post) => post.content.toLowerCase().includes(q) || post.hashtags.some((tag) => tag.includes(q))
+    );
+  }, [posts, searchTerm, activeTag]);
+
+  const createPost = async ({ content, file }) => {
+    const stamp = now();
+    const post = {
+      id: crypto.randomUUID(),
+      content,
+      imageData: file ? await toBase64(file) : '',
+      hashtags: extractHashtags(content),
+      comments: [],
+      createdAt: stamp,
+      updatedAt: stamp,
+      syncStatus: online ? 'synced' : 'pending'
+    };
+    await localDb.putPost(post);
+    if (online) await api.createPost(post);
+    else await enqueue('createPost', post);
+    await refreshLocal();
+  };
+
+  const updatePost = async (id, updates) => {
+    const post = posts.find((p) => p.id === id);
+    const merged = {
+      ...post,
+      ...updates,
+      hashtags: extractHashtags(updates.content ?? post.content),
+      updatedAt: now(),
+      syncStatus: online ? 'synced' : 'pending'
+    };
+    await localDb.putPost(merged);
+    if (online) await api.updatePost(id, merged);
+    else await enqueue('updatePost', merged);
+    await refreshLocal();
+  };
+
+  const deletePost = async (id) => {
+    await localDb.deletePost(id);
+    if (online) await api.deletePost(id);
+    else await enqueue('deletePost', { id });
+    await refreshLocal();
+  };
+
+  const replaceComments = async (postId, updater) => {
+    const post = posts.find((p) => p.id === postId);
+    if (!post) return;
+    const comments = updater(post.comments);
+    const updatedAt = now();
+    const syncStatus = online ? 'synced' : 'pending';
+    const updated = { ...post, comments, updatedAt, syncStatus };
+    await localDb.putPost(updated);
+    if (online) await api.replaceComments(postId, comments, updatedAt, syncStatus);
+    else await enqueue('replaceComments', { postId, comments, updatedAt, syncStatus });
+    await refreshLocal();
+  };
+
+  return (
+    <main className="app-shell">
+      <h1>Offline Social PWA</h1>
+      <SyncStatusIndicator online={online} posts={posts} />
+      <CreatePostForm onCreate={createPost} />
+      <SearchBar value={searchTerm} onChange={setSearchTerm} />
+      <HashtagView activeTag={activeTag} posts={posts} onSelectTag={setActiveTag} />
+      <PostFeed
+        posts={visiblePosts}
+        onEditPost={updatePost}
+        onDeletePost={deletePost}
+        onAddComment={(postId, content) =>
+          replaceComments(postId, (comments) => [...comments, { id: crypto.randomUUID(), content, createdAt: now(), updatedAt: now() }])
+        }
+        onEditComment={(postId, commentId, content) =>
+          replaceComments(postId, (comments) =>
+            comments.map((c) => (c.id === commentId ? { ...c, content, updatedAt: now() } : c))
+          )
+        }
+        onDeleteComment={(postId, commentId) =>
+          replaceComments(postId, (comments) => comments.filter((c) => c.id !== commentId))
+        }
+        onTagClick={setActiveTag}
+      />
+    </main>
+  );
+}
